# Copy to terraform.tfvars and fill in the values before running terraform apply.
# All sensitive values should be stored in AWS Secrets Manager for production.

aws_region   = "eu-central-1"
environment  = "production"
cluster_name = "hrs-platform"

# EKS
kubernetes_version = "1.29"
node_instance_type = "t3.medium"
node_min           = 2
node_max           = 5
node_desired       = 2

# Networking
vpc_cidr = "10.0.0.0/16"

# Database — change password before use
db_username      = "dbmaster"
db_password      = "CHANGE_ME_strong_password_here"
auth_db_name     = "auth_db"
registry_db_name = "registry_db"

# Application secrets
jwt_secret            = "CHANGE_ME_random_256bit_secret"
new_relic_license_key = "CHANGE_ME_new_relic_license_key"

# TLS / Ingress — create ACM cert first, then paste ARN here
acm_certificate_arn = "arn:aws:acm:eu-central-1:ACCOUNT_ID:certificate/CERT_ID"
domain_name         = "platform.example.com"

# Jenkins
jenkins_admin_password = "CHANGE_ME_jenkins_password"

# Initially empty; add tenants via Jenkins tenant-provision pipeline
tenant_ids = []
